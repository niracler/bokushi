---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import PostList from "../../components/PostList.astro";
import { t } from "../../i18n/ui";
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={t("zh", "site.title")} description={t("zh", "site.description")} />
	</head>
	<body>
		<Header />
		<main id="main-content" class="page-shell max-w-5xl section-stack">
			<PostList locale="zh" />
		</main>
		<Footer />
	</body>
</html>
