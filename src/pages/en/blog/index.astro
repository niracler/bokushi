---
import BaseHead from "../../../components/BaseHead.astro";
import Footer from "../../../components/Footer.astro";
import Header from "../../../components/Header.astro";
import PostList from "../../../components/PostList.astro";
import { t } from "../../../i18n/ui";
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`Blog - ${t("en", "site.title")}`} description="Blog posts in English" />
    </head>
    <body>
        <Header />
        <main id="main-content" class="page-shell max-w-5xl section-stack">
            <PostList locale="en" />
        </main>
        <Footer />
    </body>
</html>
