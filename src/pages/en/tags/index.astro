---
import { getCollection } from "astro:content";
import BaseHead from "../../../components/BaseHead.astro";
import Footer from "../../../components/Footer.astro";
import Header from "../../../components/Header.astro";
import { t } from "../../../i18n/ui";
import { localePath, parsePostId } from "../../../utils/i18n";

const [blogPosts, monthlyPosts, tilPosts] = await Promise.all([
    getCollection("blog"),
    getCollection("monthly"),
    getCollection("til"),
]);
const posts = [...blogPosts, ...monthlyPosts, ...tilPosts].filter((post) => {
    if (post.data.hidden) return false;
    const { locale } = parsePostId(post.id);
    return locale === "en";
});
const tagCountMap = new Map<string, number>();

posts.forEach((post) => {
    (post.data.tags || []).forEach((tag) => {
        if (!tag) return;
        tagCountMap.set(tag, (tagCountMap.get(tag) ?? 0) + 1);
    });
});

const sortedTags = Array.from(tagCountMap.entries()).sort((a, b) => {
    if (b[1] === a[1]) {
        return a[0].localeCompare(b[0]);
    }
    return b[1] - a[1];
});

const primaryTags = sortedTags.filter(([_, count]) => count >= 3);
const secondaryTags = sortedTags.filter(([_, count]) => count < 3);

const pageTitle = "Tag Index";
const siteTitle = t("en", "site.title");
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${pageTitle} | ${siteTitle}`} description="Browse all tags from English posts" />
	</head>
	<body>
		<Header />
		<main id="main-content" class="page-shell max-w-5xl section-stack">
			<header class="space-y-3 text-center">
				<h1 class="text-3xl font-semibold tracking-tight text-primary sm:text-4xl">{pageTitle}</h1>
				<p class="text-sm uppercase tracking-[0.25em] text-[color-mix(in srgb, var(--color-text-muted) 70%, transparent)]">
					Explore all topics from here
				</p>
			</header>
			<section class="space-y-16">
				{primaryTags.length > 0 && (
					<div class="space-y-3">
						<h2 class="text-center text-xs font-semibold uppercase tracking-[0.38em] text-[color-mix(in srgb, var(--color-text-muted) 70%, transparent)]">
							Popular Tags
						</h2>
						<div class="flex flex-wrap justify-center gap-3 sm:gap-4">
							{primaryTags.map(([tag, count]) => (
								<p class="m-0">
									<a
										href={localePath(`/tags/${tag}`, "en")}
										class="inline-flex items-center rounded-full border border-border-subtle bg-surface px-4 py-2.5 text-sm font-medium text-secondary transition-colors hover:border-accent hover:bg-accent-soft hover:text-accent sm:py-2"
									>
										<span>{tag}</span>
										<span class="ml-2 text-xs font-semibold text-muted">
											{count}
										</span>
									</a>
								</p>
							))}
						</div>
					</div>
				)}

				{secondaryTags.length > 0 && (
					<div class="space-y-3">
						<h2 class="text-center text-xs font-semibold uppercase tracking-[0.38em] text-[color-mix(in srgb, var(--color-text-muted) 70%, transparent)]">
							Other Tags
						</h2>
						<div class="flex flex-wrap justify-center gap-3 sm:gap-4">
							{secondaryTags.map(([tag, count]) => (
								<p class="m-0">
									<a
										href={localePath(`/tags/${tag}`, "en")}
										class="inline-flex items-center rounded-full border border-border-subtle bg-surface px-4 py-2.5 text-sm font-medium text-secondary transition-colors hover:border-accent hover:bg-accent-soft hover:text-accent sm:py-2"
									>
									<span>{tag}</span>
									<span class="ml-2 text-[0.75rem] font-semibold text-[color-mix(in srgb, var(--color-text-muted) 65%, transparent)]">
										{count}
									</span>
									</a>
								</p>
							))}
						</div>
					</div>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
