---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../layouts/BlogPost.astro";

export const prerender = true;

export async function getStaticPaths() {
    const [blogPosts, monthlyPosts, tilPosts] = await Promise.all([
        getCollection("blog"),
        getCollection("monthly"),
        getCollection("til"),
    ]);
    const posts = [...blogPosts, ...monthlyPosts, ...tilPosts];
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post, allPosts: posts },
    }));
}
type BlogEntry = CollectionEntry<"blog"> | CollectionEntry<"monthly"> | CollectionEntry<"til">;
type Props = { post: BlogEntry; allPosts: BlogEntry[] };

const { post, allPosts } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);

// Compute related posts by tag similarity
const currentTags = post.data.tags ?? [];
const otherPosts = allPosts.filter((p) => p.id !== post.id && !p.data.hidden);

// Only show posts that actually share tags (no fallback to "most recent")
let relatedPosts: BlogEntry[] = [];
if (currentTags.length > 0) {
    const scored = otherPosts.map((p) => {
        const pTags = p.data.tags ?? [];
        const shared = currentTags.filter((t: string) => pTags.includes(t)).length;
        return { post: p, score: shared };
    });
    scored.sort((a, b) => {
        if (b.score !== a.score) return b.score - a.score;
        return b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf();
    });
    relatedPosts = scored
        .filter((s) => s.score > 0)
        .slice(0, 3)
        .map((s) => s.post);
}
---

<BlogPost
    {...post.data}
    body={post.body}
    headings={headings}
    lastModified={remarkPluginFrontmatter?.lastModified}
    lastModifiedCommitUrl={remarkPluginFrontmatter?.lastModifiedCommitUrl}
    relatedPosts={relatedPosts}
>
    <Content />
</BlogPost>
