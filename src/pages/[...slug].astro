---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../layouts/BlogPost.astro";
import { parsePostId, postUrl } from "../utils/i18n";

export const prerender = true;

export async function getStaticPaths() {
    const [blogPosts, monthlyPosts, tilPosts] = await Promise.all([
        getCollection("blog"),
        getCollection("monthly"),
        getCollection("til"),
    ]);
    const posts = [...blogPosts, ...monthlyPosts, ...tilPosts];
    return posts.map((post) => {
        const { locale, slug } = parsePostId(post.id);
        // Default locale (zh) → /slug, other locales → /en/slug
        const urlSlug = locale === "zh" ? slug : `${locale}/${slug}`;
        return {
            params: { slug: urlSlug },
            props: { post, allPosts: posts },
        };
    });
}
type BlogEntry = CollectionEntry<"blog"> | CollectionEntry<"monthly"> | CollectionEntry<"til">;
type Props = { post: BlogEntry; allPosts: BlogEntry[] };

const { post, allPosts } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);
const { locale, slug: baseSlug } = parsePostId(post.id);

// Build hreflang alternates for SEO (only when a translation exists)
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const blogPosts = allPosts.filter((p): p is CollectionEntry<"blog"> => p.collection === "blog");
const translationEntry = blogPosts.find((p) => {
    const parsed = parsePostId(p.id);
    return parsed.slug === baseSlug && parsed.locale !== locale;
});
const hreflangAlternates: { locale: string; url: string }[] = [];
if (translationEntry) {
    // Both directions + x-default pointing to zh
    hreflangAlternates.push(
        { locale: "zh", url: `${siteUrl}/${baseSlug}` },
        { locale: "en", url: `${siteUrl}/en/${baseSlug}` },
        { locale: "x-default", url: `${siteUrl}/${baseSlug}` },
    );
}

// Translation link data for LanguageSwitcher (reuse translationEntry from above)
const translationUrl = translationEntry ? postUrl(translationEntry.id) : undefined;
const translationLocale = translationEntry ? parsePostId(translationEntry.id).locale : undefined;

// Compute related posts by tag similarity (same locale only)
const currentTags = post.data.tags ?? [];
const otherPosts = allPosts.filter(
    (p) => p.id !== post.id && !p.data.hidden && parsePostId(p.id).locale === locale,
);

// Only show posts that actually share tags (no fallback to "most recent")
let relatedPosts: BlogEntry[] = [];
if (currentTags.length > 0) {
    const scored = otherPosts.map((p) => {
        const pTags = p.data.tags ?? [];
        const shared = currentTags.filter((t: string) => pTags.includes(t)).length;
        return { post: p, score: shared };
    });
    scored.sort((a, b) => {
        if (b.score !== a.score) return b.score - a.score;
        return b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf();
    });
    relatedPosts = scored
        .filter((s) => s.score > 0)
        .slice(0, 3)
        .map((s) => s.post);
}
---

<BlogPost
    {...post.data}
    locale={locale}
    postId={post.id}
    body={post.body}
    headings={headings}
    lastModified={remarkPluginFrontmatter?.lastModified}
    lastModifiedCommitUrl={remarkPluginFrontmatter?.lastModifiedCommitUrl}
    relatedPosts={relatedPosts}
    hreflangAlternates={hreflangAlternates}
    translationUrl={translationUrl}
    translationLocale={translationLocale}
>
    <Content />
</BlogPost>
