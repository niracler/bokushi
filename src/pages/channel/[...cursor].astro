---
/**
 * Telegram Channel Display Page — v4 「剪报本」 layout
 *
 * Structure: narrow strip at top + 3-col layout (month spine | feed | rail)
 * Feed is grouped by day, with 2-col CSS-columns masonry per day group.
 * Cards come in 5 variants detected from the post shape (see telegram.ts).
 *
 * @author Niracler
 */

import BaseHead from "../../components/BaseHead.astro";
import ChannelDayDivider from "../../components/channel/ChannelDayDivider.astro";
import ChannelRail from "../../components/channel/ChannelRail.astro";
import PostCard from "../../components/channel/PostCard.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Lightbox from "../../components/Lightbox.astro";
import type { TelegramChannel } from "../../utils/telegram";
import {
    collectForwardSources,
    fetchTelegramChannel,
    groupPostsByDay,
    tallyByType,
} from "../../utils/telegram";

// Enable server-side rendering for this dynamic route
export const prerender = false;

const { cursor } = Astro.params;
const CHANNEL_USERNAME = "tomoko_channel";
const CACHE_SECONDS = 300;

function parseCursor(cursor: string | undefined): {
    type: "before" | "after" | null;
    value: string | undefined;
} {
    if (!cursor) return { type: null, value: undefined };
    if (cursor.startsWith("before-")) return { type: "before", value: cursor.slice(7) };
    if (cursor.startsWith("after-")) return { type: "after", value: cursor.slice(6) };
    return { type: null, value: undefined };
}

const { type: cursorType, value: cursorValue } = parseCursor(cursor);

let channelData: TelegramChannel | undefined;
let error: string | null = null;

try {
    const options: { before?: string; after?: string; minPosts?: number } = { minPosts: 40 };
    if (cursorType === "before" && cursorValue) {
        options.before = cursorValue;
    } else if (cursorType === "after" && cursorValue) {
        options.after = cursorValue;
    }

    channelData = await fetchTelegramChannel(CHANNEL_USERNAME, options);
} catch (e) {
    error = e instanceof Error ? e.message : "Failed to load channel";
    console.error("Error loading Telegram channel:", e);
}

const firstPostId = channelData?.posts?.[0]?.id;
const lastPostId = channelData?.posts?.[channelData.posts.length - 1]?.id;

const hasNewerPosts = cursorType === "before" || cursorType === "after";
const hasOlderPosts = channelData?.posts && channelData.posts.length > 0;

Astro.response.headers.set(
    "Cache-Control",
    `public, max-age=${CACHE_SECONDS}, stale-while-revalidate=30`,
);

const posts = channelData?.posts ?? [];
const dayGroups = groupPostsByDay(posts);
const typeCounts = tallyByType(posts);
const forwardSources = collectForwardSources(posts, 4);

// Track which days are the first of their month — only those get the month anchor id,
// so deep links like /channel#m-2026-04 still work for bookmarking a specific month.
const monthAnchorSeen = new Set<string>();
const dayGroupsWithAnchor = dayGroups.map((group) => {
    const needsAnchor = !monthAnchorSeen.has(group.monthAnchor);
    if (needsAnchor) monthAnchorSeen.add(group.monthAnchor);
    return { ...group, anchorId: needsAnchor ? group.monthAnchor : undefined };
});

// Eyebrow "YYYY·MM" — latest month present in this slice
const latestPost = posts[0];
const latestDate = latestPost?.datetime ? new Date(latestPost.datetime) : null;
const currentMonthLabel =
    latestDate && !Number.isNaN(latestDate.getTime())
        ? `${latestDate.getUTCFullYear()}·${String(latestDate.getUTCMonth() + 1).padStart(2, "0")}`
        : undefined;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead
      title={channelData?.title ? `${channelData.title} - 动态` : '动态'}
      description={channelData?.description || '我的最新动态和分享'}
      image={channelData?.avatar}
    />
  </head>
  <body>
    <Header />
    <main id="main-content" class="page-shell max-w-5xl section-stack">
      {error ? (
        <div class="error-message surface-card">
          <h1>加载频道失败</h1>
          <p>{error}</p>
          <p>
            请访问 <a href={`https://t.me/${CHANNEL_USERNAME}`} target="_blank" rel="noopener noreferrer">
              Telegram 频道
            </a>
          </p>
        </div>
      ) : channelData ? (
        <>
          <div class="channel-layout">
            <section class="channel-main">
              {dayGroupsWithAnchor.map((group) => (
                <>
                  <ChannelDayDivider
                    dayLabel={group.dayLabel}
                    weekday={group.weekday}
                    postCount={group.posts.length}
                    monthAnchor={group.anchorId}
                  />
                  <div class="feed">
                    {group.posts.map((post) => (
                      <PostCard post={post} channelUsername={CHANNEL_USERNAME} />
                    ))}
                  </div>
                </>
              ))}

              <nav class="pager">
                {hasNewerPosts && firstPostId && (
                  <a href={`/channel/after-${firstPostId}`} class="pager__link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    更新的
                  </a>
                )}
                <a
                  href="/channel"
                  class:list={["pager__link", { "pager__link--active": !cursor }]}
                >
                  最新
                </a>
                {hasOlderPosts && lastPostId && (
                  <a href={`/channel/before-${lastPostId}`} class="pager__link">
                    更早的
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                )}
              </nav>
            </section>

            <ChannelRail
              channelTitle={channelData.title}
              channelAvatar={channelData.avatar}
              username={CHANNEL_USERNAME}
              currentMonthLabel={currentMonthLabel}
              description={channelData.description}
              typeCounts={typeCounts}
              forwardSources={forwardSources}
            />
          </div>
        </>
      ) : null}
    </main>
    <Footer />
    <Lightbox id="channel-lightbox" selector=".card__content img:not([data-lightbox-skip]), .telegram-post-image" />
  </body>
</html>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.card__content img').forEach((element) => {
      const img = element as HTMLImageElement;
      img.classList.add('telegram-post-image');
      img.loading = img.loading || 'lazy';
    });

    document.querySelectorAll<HTMLElement>('.card__content table').forEach((table) => {
      if (table.parentElement?.classList.contains('table-scroll-wrapper')) return;
      const wrapper = document.createElement('div');
      wrapper.className = 'table-scroll-wrapper';
      table.parentNode?.insertBefore(wrapper, table);
      wrapper.appendChild(table);
    });

    // Client-side fallback: detect remaining raw pipe-table text and wrap in <pre>
    document.querySelectorAll<HTMLElement>('.card__content').forEach((content) => {
      const walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT);
      const pipeLineRe = /^\s*\|.+\|\s*$/;
      const sepRe = /^\s*\|[\s\-:]+(\|[\s\-:]+)+\|\s*$/;
      const nodesToReplace: { node: Text; tableText: string; before: string; after: string }[] = [];

      let node: Text | null;
      while ((node = walker.nextNode() as Text | null)) {
        const text = node.textContent || '';
        const lines = text.split('\n');
        let tableStart = -1;

        for (let idx = 0; idx < lines.length; idx++) {
          if (pipeLineRe.test(lines[idx])) {
            if (tableStart === -1) tableStart = idx;
            if (
              idx >= tableStart + 1 &&
              sepRe.test(lines[tableStart + 1]) &&
              idx >= tableStart + 2
            ) {
              // Continue collecting
            }
          } else {
            if (
              tableStart !== -1 &&
              idx - tableStart >= 3 &&
              sepRe.test(lines[tableStart + 1])
            ) {
              const before = lines.slice(0, tableStart).join('\n');
              const tableText = lines.slice(tableStart, idx).join('\n');
              const after = lines.slice(idx).join('\n');
              nodesToReplace.push({ node, tableText, before, after });
            }
            tableStart = -1;
          }
        }
        if (
          tableStart !== -1 &&
          lines.length - tableStart >= 3 &&
          sepRe.test(lines[tableStart + 1])
        ) {
          const before = lines.slice(0, tableStart).join('\n');
          const tableText = lines.slice(tableStart).join('\n');
          nodesToReplace.push({ node, tableText, before, after: '' });
        }
      }

      for (const { node: textNode, tableText, before, after } of nodesToReplace) {
        const frag = document.createDocumentFragment();
        if (before) frag.appendChild(document.createTextNode(before));
        const pre = document.createElement('pre');
        pre.className = 'pipe-table-fallback';
        pre.textContent = tableText;
        frag.appendChild(pre);
        if (after) frag.appendChild(document.createTextNode(after));
        textNode.parentNode?.replaceChild(frag, textNode);
      }
    });

    // Collapse long posts based on rendered height
    const HEIGHT_THRESHOLD = 320; // 20rem, matches card CSS

    document.querySelectorAll<HTMLElement>('[data-post-content-wrapper]').forEach((wrapper) => {
      const content = wrapper.querySelector<HTMLElement>('.card__content');
      const btn = wrapper.querySelector<HTMLButtonElement>('[data-expand-btn]');
      const label = btn?.querySelector<HTMLElement>('[data-expand-label]');
      if (!content || !btn || !label) return;

      if (content.scrollHeight > HEIGHT_THRESHOLD) {
        wrapper.dataset.collapsed = 'true';
        btn.hidden = false;
        btn.setAttribute('aria-expanded', 'false');

        btn.addEventListener('click', () => {
          const isCollapsed = wrapper.dataset.collapsed === 'true';
          wrapper.dataset.collapsed = isCollapsed ? 'false' : 'true';
          label.textContent = isCollapsed ? '收起' : '展开全文';
          btn.setAttribute('aria-label', isCollapsed ? '收起' : '展开全文');
          btn.setAttribute('aria-expanded', isCollapsed ? 'true' : 'false');
        });
      }
    });
  });
</script>

<style>
  /* =================================================================
   * Layout: feed (main) + channel rail
   * Below 900px the rail drops to avoid squeezing the feed.
   * ================================================================= */
  .channel-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 14rem;
    gap: var(--space-6);
    align-items: start;
  }

  .channel-main {
    min-width: 0;
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .channel-layout {
      grid-template-columns: 1fr;
    }

    .channel-layout > :global(.rail) {
      position: static;
      max-height: none;
      order: -1;
    }
  }

  /* =================================================================
   * Per-day masonry feed — 2-col CSS columns
   * Packs variable-height cards tightly (the 错落有致 look).
   * Reading order: fill left col top-to-bottom, then right col.
   * ================================================================= */
  .feed {
    column-count: 2;
    column-gap: var(--space-4);
  }

  .feed > :global(*) {
    break-inside: avoid;
    -webkit-column-break-inside: avoid;
    page-break-inside: avoid;
    margin-bottom: var(--space-4);
    display: block;
  }

  @media (max-width: 760px) {
    .feed {
      column-count: 1;
    }
  }

  /* =================================================================
   * Pager
   * ================================================================= */
  .pager {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border-soft);
  }

  .pager__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-surface);
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .pager__link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-dark);
  }

  .pager__link--active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .pager__link--active:hover {
    background: var(--color-accent-dark);
    border-color: var(--color-accent-dark);
    color: #fff;
  }

  /* =================================================================
   * Error state
   * ================================================================= */
  .error-message {
    text-align: center;
    padding: var(--space-8) var(--space-4);
    color: var(--color-text-secondary);
  }

  .error-message h1 {
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .error-message a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .pager {
      flex-wrap: wrap;
    }
  }
</style>
