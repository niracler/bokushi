---
import type { CardType, TelegramPost } from "../../utils/telegram";
import { detectCardType } from "../../utils/telegram";
import FormattedDate from "../FormattedDate.astro";
import LinkPreviewCard from "./LinkPreviewCard.astro";
import ReplyQuote from "./ReplyQuote.astro";

interface Props {
    post: TelegramPost;
    channelUsername: string;
    /** Override the auto-detected type if you need a specific visual variant. */
    variant?: CardType;
}

const { post, channelUsername, variant } = Astro.props;

const cardType: CardType = variant ?? detectCardType(post);
---

<article
    class:list={["card", `card--${cardType}`]}
    id={`post-${post.id}`}
>
    {post.replyInfo && <ReplyQuote reply={post.replyInfo} />}

    {cardType === "fwd" && post.forwardedFrom && (
        <div class="card__fwd-from">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
                <path d="M5 12L19 12M19 12l-6-6M19 12l-6 6" />
            </svg>
            {post.forwardedFromLink ? (
                <a href={post.forwardedFromLink} target="_blank" rel="noopener noreferrer">
                    @{post.forwardedFrom}
                </a>
            ) : (
                <span>@{post.forwardedFrom}</span>
            )}
        </div>
    )}

    <div
        class="card__content-wrapper"
        id={`post-content-${post.id}`}
        data-post-content-wrapper
    >
        <div class="card__content" set:html={post.content} />
        <button
            class="card__expand-btn"
            data-expand-btn
            aria-label="展开全文"
            aria-expanded="false"
            aria-controls={`post-content-${post.id}`}
            hidden
        >
            <span data-expand-label>展开全文</span>
            <svg class="card__expand-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9l6 6 6-6" />
            </svg>
        </button>
    </div>

    {post.linkPreview && <LinkPreviewCard preview={post.linkPreview} />}

    <footer class="card__meta">
        <div class="card__meta-left">
            {post.datetime && (
                <time datetime={post.datetime} class="card__date">
                    <FormattedDate date={new Date(post.datetime)} />
                </time>
            )}
        </div>

        {post.hashtags && post.hashtags.length > 0 && (
            <div class="card__tags">
                {post.hashtags.map(tag => (
                    <a
                        href={`https://t.me/s/${channelUsername}?q=%23${encodeURIComponent(tag)}`}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        #{tag}
                    </a>
                ))}
            </div>
        )}
    </footer>
</article>

<style>
    /* =================================================================
     * Card base — v4 剪报本 look: white paper, thin border, soft shadow
     * ================================================================= */
    .card {
        position: relative;
        background: var(--color-bg-surface);
        border: 1px solid var(--color-border-soft);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
        padding: var(--space-3) var(--space-4);
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        min-width: 0;
        overflow: hidden;
        color: var(--color-text-primary);
        font-size: 0.94rem;
        line-height: 1.62;
        letter-spacing: 0.01em;
        transition:
            border-color var(--transition-base),
            box-shadow var(--transition-base);
    }

    .card:hover {
        border-color: var(--color-border);
        box-shadow: var(--shadow-strong);
    }

    /* Forward: left accent bar identifies the type at a glance. */
    .card--fwd {
        border-left: 3px solid var(--color-accent);
        padding-left: calc(var(--space-4) - 2px);
    }

    .card__fwd-from {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-family: "Fira Code", "SFMono-Regular", Menlo, monospace;
        font-size: 0.7rem;
        color: var(--color-accent-dark);
        font-weight: 700;
        letter-spacing: 0.04em;
    }

    .card__fwd-from a {
        color: inherit;
        text-decoration: none;
    }

    .card__fwd-from a:hover {
        text-decoration: underline;
    }

    /* =================================================================
     * Content rendering (markdown HTML from Telegram)
     * ================================================================= */
    .card__content {
        min-width: 0;
        color: var(--color-text-primary);
        white-space: pre-wrap;
        overflow-wrap: anywhere;
    }

    .card__content :global(a) {
        color: var(--color-accent);
        text-decoration: none;
        transition: opacity var(--transition-base);
        overflow-wrap: anywhere;
    }

    .card__content :global(a:hover) {
        opacity: 0.8;
        text-decoration: underline;
    }

    .card__content :global(img) {
        max-width: 100%;
        height: auto;
    }

    .card__content :global(.telegram-images) {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2px;
        margin: var(--space-3) 0;
        border-radius: var(--radius-sm);
        overflow: hidden;
    }

    .card__content :global(.telegram-images):has(> :only-child) {
        grid-template-columns: 1fr;
        gap: 0;
    }

    .card__content :global(.telegram-post-image) {
        width: 100%;
        height: 100%;
        aspect-ratio: 1;
        display: block;
        object-fit: cover;
        background: var(--color-bg-muted);
        cursor: pointer;
        border-radius: 0;
    }

    .card__content :global(.telegram-images):has(> :only-child) :global(.telegram-post-image) {
        aspect-ratio: auto;
        height: auto;
        object-fit: contain;
        border-radius: var(--radius-sm);
        box-shadow: var(--shadow-soft);
    }

    .card__content :global(ol),
    .card__content :global(ul) {
        margin: var(--space-2) 0;
        padding-left: 0;
        list-style: none;
    }

    .card__content :global(ol li),
    .card__content :global(ul li) {
        position: relative;
        padding-left: var(--space-5);
        margin-bottom: var(--space-1);
    }

    .card__content :global(ol) {
        counter-reset: list-counter;
    }

    .card__content :global(ol li) {
        counter-increment: list-counter;
    }

    .card__content :global(ol li::before) {
        content: counter(list-counter) ".";
        position: absolute;
        left: 0;
        color: var(--color-text-muted);
        font-weight: 500;
    }

    .card__content :global(ul li::before) {
        content: "\2022";
        position: absolute;
        left: var(--space-2);
        color: var(--color-text-muted);
    }

    /* Code block — v4 gives code cards a slightly tighter, monospaced look */
    .card__content :global(pre) {
        background: color-mix(in srgb, var(--color-bg-muted) 60%, var(--color-bg-surface));
        padding: var(--space-3);
        border-radius: var(--radius-sm);
        overflow-x: auto;
        border: 1px solid var(--color-border-soft);
        white-space: pre-wrap;
        word-break: break-word;
        font-family: "Fira Code", "SFMono-Regular", Menlo, monospace;
        font-size: 0.82rem;
        line-height: 1.55;
    }

    .card__content :global(code) {
        font-family: "Fira Code", "SFMono-Regular", Menlo, monospace;
        font-size: 0.88em;
    }

    .card__content :global(:not(pre) > code) {
        background: var(--color-bg-muted);
        padding: 0.04em 0.4em;
        border-radius: var(--radius-xs);
        color: var(--color-accent-dark);
        border: 1px solid var(--color-border-soft);
    }

    .card__content :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        padding: var(--space-2) var(--space-3);
        margin: var(--space-3) 0;
        color: var(--color-text-secondary);
        background: var(--color-bg-muted);
        border-radius: 0 var(--radius-xs) var(--radius-xs) 0;
        font-style: italic;
    }

    .card__content :global(.table-scroll-wrapper) {
        overflow-x: auto;
        margin: var(--space-3) 0;
        -webkit-overflow-scrolling: touch;
    }

    .card__content :global(.table-scroll-wrapper) :global(table) {
        margin: 0;
    }

    .card__content :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: var(--space-3) 0;
        font-size: 0.88rem;
        white-space: normal;
    }

    .card__content :global(thead) {
        background: var(--color-bg-muted);
    }

    .card__content :global(th),
    .card__content :global(td) {
        padding: var(--space-2) var(--space-3);
        border: 1px solid var(--color-border-soft);
        text-align: left;
        white-space: normal;
        word-break: break-word;
    }

    .card__content :global(th) {
        font-weight: 600;
        color: var(--color-text-primary);
    }

    .card__content :global(tr:nth-child(even)) {
        background: var(--color-bg-muted);
    }

    .card__content :global(tr:hover) {
        background: var(--color-accent-soft);
    }

    .card__content :global(.pipe-table-fallback) {
        background: var(--color-bg-muted);
        padding: var(--space-3);
        border-radius: var(--radius-sm);
        overflow-x: auto;
        border: 1px solid var(--color-border-soft);
        white-space: pre;
        font-family: "Fira Code", "SFMono-Regular", Menlo, monospace;
        font-size: 0.82rem;
        line-height: 1.55;
        -webkit-overflow-scrolling: touch;
    }

    /* =================================================================
     * Content collapse for long posts
     * ================================================================= */
    .card__content-wrapper {
        position: relative;
    }

    .card__content-wrapper[data-collapsed="true"] .card__content {
        max-height: 20rem;
        overflow: hidden;
        -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
        mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
    }

    .card__expand-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-1);
        margin-top: var(--space-2);
        padding: var(--space-1) var(--space-3);
        border: 1px solid var(--color-border-soft);
        border-radius: var(--radius-sm);
        background: var(--color-bg-muted);
        color: var(--color-text-secondary);
        font-size: 0.76rem;
        font-weight: 500;
        font-family: inherit;
        cursor: pointer;
        transition:
            border-color var(--transition-base),
            color var(--transition-base);
    }

    .card__expand-btn:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
    }

    .card__expand-icon {
        transition: transform var(--transition-base);
    }

    .card__content-wrapper[data-collapsed="false"] .card__expand-icon {
        transform: rotate(180deg);
    }

    /* =================================================================
     * Meta footer (time + tags)
     * ================================================================= */
    .card__meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
        font-family: "Fira Code", "SFMono-Regular", Menlo, monospace;
        font-size: 0.66rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-text-muted);
        margin-top: 0.2rem;
    }

    .card__meta-left {
        display: flex;
        align-items: center;
        gap: var(--space-2);
    }

    .card__date {
        color: var(--color-text-secondary);
        font-weight: 600;
        letter-spacing: 0.04em;
        font-variant-numeric: tabular-nums;
    }

    .card__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem 0.5rem;
        font-size: 0.72rem;
        letter-spacing: 0.02em;
        text-transform: none;
    }

    .card__tags a {
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color var(--transition-base);
    }

    .card__tags a:hover {
        color: var(--color-accent-dark);
    }

    @media (max-width: 640px) {
        .card__content-wrapper[data-collapsed="true"] .card__content {
            max-height: 14rem;
        }

        .card__meta {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
