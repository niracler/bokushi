---
import type { LinkPreview } from "../../utils/telegram";

interface Props {
    preview: LinkPreview;
}

const { preview } = Astro.props;
---

<a
    href={preview.url}
    target="_blank"
    rel="noopener noreferrer"
    class="link-preview"
>
    {preview.imageUrl && (
        <div class="link-preview__thumb">
            <img src={preview.imageUrl} alt="" loading="lazy" />
        </div>
    )}
    <div class="link-preview__body">
        {preview.siteName && (
            <span class="link-preview__site">{preview.siteName}</span>
        )}
        {preview.title && (
            <h4 class="link-preview__title">{preview.title}</h4>
        )}
        {preview.description && (
            <p class="link-preview__desc">{preview.description}</p>
        )}
    </div>
</a>

<style>
    /* Embedded preview block — NOT a nested card.
       Matches v4 剪报本 style: muted background, thin border, small radius, no shadow. */
    .link-preview {
        display: flex;
        gap: 0.6rem;
        align-items: stretch;
        padding: 0.55rem;
        border-radius: var(--radius-sm);
        background: var(--color-bg-muted);
        border: 1px solid var(--color-border-soft);
        text-decoration: none;
        color: inherit;
        transition: all var(--transition-base);
        min-width: 0;
        overflow: hidden;
    }

    .link-preview:hover {
        border-color: var(--color-accent);
        background: color-mix(in srgb, var(--color-accent) 6%, var(--color-bg-muted));
    }

    .link-preview__thumb {
        flex: 0 0 4rem;
        aspect-ratio: 1;
        border-radius: 4px;
        overflow: hidden;
        background: var(--color-bg-muted);
    }

    .link-preview__thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .link-preview__body {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        flex: 1;
        min-width: 0;
    }

    .link-preview__site {
        font-family: "Fira Code", "SFMono-Regular", Menlo, monospace;
        font-size: 0.6rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--color-accent-dark);
        font-weight: 700;
    }

    .link-preview__title {
        margin: 0;
        font-size: 0.94rem;
        line-height: 1.35;
        font-weight: 700;
        color: var(--color-text-primary);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        overflow-wrap: anywhere;
    }

    .link-preview__desc {
        margin: 0;
        font-size: 0.8rem;
        color: var(--color-text-secondary);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        overflow-wrap: anywhere;
    }
</style>
