---
import { getCollection } from "astro:content";
import type { Locale } from "../utils/i18n";
import { parsePostId, postUrl } from "../utils/i18n";

type Props = {
    /** The content collection ID of the current post (e.g. "zh/elegant") */
    postId: string;
};

const { postId } = Astro.props;
const { locale, slug } = parsePostId(postId);

// Find the translation counterpart by matching base slug in the other locale
const targetLocale: Locale = locale === "zh" ? "en" : "zh";
const allBlogPosts = await getCollection("blog");

const translationEntry = allBlogPosts.find((p) => {
    const parsed = parsePostId(p.id);
    return parsed.slug === slug && parsed.locale === targetLocale;
});

const label = targetLocale === "en" ? "Read in English" : "中文版";
---

{translationEntry && (
    <a
        href={postUrl(translationEntry.id)}
        class="inline-flex items-center gap-1.5 text-sm transition-colors"
        style="color: var(--color-text-muted);"
        onmouseover="this.style.color='var(--color-accent)'"
        onmouseout="this.style.color='var(--color-text-muted)'"
    >
        <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
        >
            <path
                d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"
                stroke="currentColor"
                stroke-width="1.5"
            />
            <path
                d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"
                stroke="currentColor"
                stroke-width="1.5"
            />
        </svg>
        {label}
    </a>
)}
