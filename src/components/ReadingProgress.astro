---
// ReadingProgress.astro
// A thin fixed bar at the top of the viewport that tracks scroll progress through the article.
// Uses CSS scaleX transform for GPU-accelerated animation. No layout shift (overlay only).
---

<div
    id="reading-progress-bar"
    aria-hidden="true"
    style="
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        z-index: 9999;
        transform-origin: left center;
        transform: scaleX(0);
        background: var(--color-accent);
        opacity: 0.85;
        pointer-events: none;
        will-change: transform;
        transition: opacity 0.2s;
    "
></div>

<script is:inline>
(function () {
    var bar = document.getElementById('reading-progress-bar');
    if (!bar) return;

    var ticking = false;

    function update() {
        // Use the article element as the scroll target so progress is relative to content
        var article = document.querySelector('article');
        if (!article) {
            ticking = false;
            return;
        }

        var articleTop = article.getBoundingClientRect().top + window.scrollY;
        var articleHeight = article.offsetHeight;
        var viewportHeight = window.innerHeight;

        // Scrollable distance: from article start to when the bottom of the article
        // reaches the bottom of the viewport
        var scrollable = articleHeight - viewportHeight;

        if (scrollable <= 0) {
            bar.style.transform = 'scaleX(1)';
            ticking = false;
            return;
        }

        var scrolled = window.scrollY - articleTop;
        var progress = Math.min(Math.max(scrolled / scrollable, 0), 1);
        bar.style.transform = 'scaleX(' + progress + ')';
        ticking = false;
    }

    window.addEventListener('scroll', function () {
        if (!ticking) {
            ticking = true;
            requestAnimationFrame(update);
        }
    }, { passive: true });

    // Initial render
    update();
})();
</script>
