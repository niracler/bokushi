{
    "name": "bokushi",
    "type": "module",
    "version": "0.0.1",
    "packageManager": "pnpm@11.12.0",
    "engines": {
        "node": ">=22.13",
        "pnpm": "11.12.0"
    },
    "scripts": {
        "dev": "astro dev",
        "dev:clean": "lsof -ti:4321 | xargs kill -9 2>/dev/null; rm -rf node_modules/.vite node_modules/.astro; astro dev",
        "build": "astro build",
        "check:ci": "pnpm lint && pnpm check:font && pnpm check:types && pnpm test && pnpm check:deps:ci && pnpm build",
        "check:deps": "knip --dependencies && pnpm dedupe --check",
        "check:deps:ci": "node scripts/check-dependencies.mjs ci",
        "check:deps:commit": "node scripts/check-dependencies.mjs commit",
        "check:design": "node scripts/check-design-rendering.mjs",
        "check:font": "python3 scripts/check-font-coverage.py",
        "check:types": "astro check",
        "preview": "astro preview",
        "astro": "astro",
        "format": "biome format --write .",
        "lint": "biome check .",
        "lint:staged": "lint-staged",
        "test": "node --test tests/*.test.mjs",
        "prepare": "husky"
    },
    "dependencies": {
        "@astrojs/cloudflare": "^13.7.0",
        "@astrojs/mdx": "^5.0.6",
        "@astrojs/rss": "^4.0.19",
        "@astrojs/sitemap": "^3.7.3",
        "@iconify-json/ri": "^1.2.10",
        "@tailwindcss/vite": "^4.3.2",
        "aes-js": "^3.1.2",
        "arctic": "^3.7.0",
        "astro": "^6.4.8",
        "astro-pagefind": "^1.8.6",
        "cheerio": "^1.2.0",
        "markdown-it": "^14.3.0",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-figure": "^1.0.1",
        "rehype-img-size": "^1.0.1",
        "rehype-mermaid": "^3.0.0",
        "rehype-picture": "^5.0.0",
        "rehype-slug": "^6.0.0",
        "remark-github-blockquote-alert": "^2.1.0",
        "sanitize-html": "^2.17.6",
        "tailwindcss": "^4.3.2"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@biomejs/biome": "^2.5.3",
        "@iconify-json/simple-icons": "^1.2.89",
        "@types/hast": "^3.0.5",
        "@types/markdown-it": "^14.1.2",
        "@types/sanitize-html": "^2.16.1",
        "husky": "^9.1.7",
        "knip": "^6.26.0",
        "lint-staged": "^16.4.0",
        "markdownlint-cli2": "^0.23.0",
        "playwright": "^1.61.1",
        "rehype-stringify": "^10.0.1",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "remark-rehype": "^11.1.2",
        "shiki": "^4.3.1",
        "unified": "^11.0.5",
        "unist-util-visit": "^5.1.0",
        "unplugin-icons": "^23.0.1",
        "wrangler": "^4.110.0"
    }
}
